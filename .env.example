# ============================================================
# Copy to .env and fill in.  Nothing here is required to build the
# knowledge base or run the Bug Submission Module — only the agent
# layer (Milestone 2) needs an LLM endpoint.
# ============================================================

# ---------- Embeddings (RAG) ----------
# Local sentence-transformers model. MiniLM is fast & CPU-friendly;
# swap to BAAI/bge-small-en-v1.5 or bge-base-en-v1.5 for higher recall.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------- Vector store ----------
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=historical_defects

# ---------- Chunking ----------
CHUNK_SIZE=800          # characters
CHUNK_OVERLAP=120

# ---------- Agent LLM (Milestone 2) ----------
# provider = huggingface | openai_compatible
LLM_PROVIDER=huggingface

# --- Path 1: Hugging Face Inference API / Providers (serverless) ---
# Get a token at https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=
# Ungated, widely served default. Bump to Qwen/Qwen2.5-72B-Instruct or
# meta-llama/Llama-3.3-70B-Instruct for stronger root-cause reasoning.
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Path 2: OpenAI-compatible server (vLLM on Thunder / Ollama / LM Studio) ---
# Used only when LLM_PROVIDER=openai_compatible.
#   Ollama:        http://localhost:11434/v1   (api key can be "ollama")
#   vLLM/Thunder:  http://<host>:8000/v1
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=not-needed
OPENAI_COMPATIBLE_MODEL=qwen2.5:7b

# ---------- Generation params ----------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
